{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist-electron",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "src/renderer/**"
  ]
}
